# =============================================================================
# Pretix + Pretalx Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# The deploy.sh script will generate secrets automatically if left blank.
# =============================================================================

# Your domain name (required)
# DNS must point tickets.<DOMAIN> and talks.<DOMAIN> to this server's IP
DOMAIN=yourdomain.com

# --- Database ---
DB_USER=pretalxtix
DB_PASSWORD=

# --- Pretix (ticketing) ---
PRETIX_SECRET_KEY=
PRETIX_IMAGE_TAG=stable

# --- Pretalx (call for papers) ---
PRETALX_SECRET_KEY=
PRETALX_IMAGE_TAG=latest

# --- Email (required for ticket confirmations and CfP notifications) ---
MAIL_FROM=noreply@yourdomain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
